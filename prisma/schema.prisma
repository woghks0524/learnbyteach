generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== 사용자 =====
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("student") // "teacher" | "student"
  createdAt DateTime @default(now())

  // 교사 관계
  courses         Course[]
  knowledgeFiles  KnowledgeFile[]
  createdStudents User[]    @relation("CreatedBy")

  // 학생 관계
  createdById     String?
  createdBy       User?     @relation("CreatedBy", fields: [createdById], references: [id])
  enrollments     CourseEnrollment[]
  instances       AIInstance[]
}

// ===== 지식파일 (교사 라이브러리) =====
model KnowledgeFile {
  id        String   @id @default(cuid())
  teacherId String
  fileName  String
  content   String
  fileType  String   // "curriculum" | "textbook" | "custom"
  subject   String   @default("") // 과목 태그
  createdAt DateTime @default(now())

  teacher User                  @relation(fields: [teacherId], references: [id])
  courses CourseKnowledgeFile[]
}

// ===== 수업-지식파일 연결 =====
model CourseKnowledgeFile {
  id              String @id @default(cuid())
  courseId         String
  knowledgeFileId String

  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  knowledgeFile KnowledgeFile @relation(fields: [knowledgeFileId], references: [id], onDelete: Cascade)

  @@unique([courseId, knowledgeFileId])
}

// ===== 수업 (핵심 단위) =====
model Course {
  id          String   @id @default(cuid())
  teacherId   String
  name        String
  subject     String
  unit        String
  gradeLevel  String
  description String?

  // AI 학생 설정
  comprehensionLevel String @default("medium")
  personality        String @default("curious")
  knownTopics        String @default("[]")
  unknownTopics      String @default("[]")
  misconceptions     String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher        User                  @relation(fields: [teacherId], references: [id])
  enrollments    CourseEnrollment[]
  instances      AIInstance[]
  knowledgeFiles CourseKnowledgeFile[]
}

// ===== 수업 등록 =====
model CourseEnrollment {
  id        String   @id @default(cuid())
  studentId String
  courseId   String
  createdAt DateTime @default(now())

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

// ===== AI 인스턴스 (학생별 포크) =====
model AIInstance {
  id         String   @id @default(cuid())
  courseId    String
  studentId  String
  createdAt  DateTime @default(now())

  comprehensionState String @default("{}")

  course   Course    @relation(fields: [courseId], references: [id])
  student  User      @relation(fields: [studentId], references: [id])
  messages Message[]

  @@unique([courseId, studentId])
}

// ===== 대화 메시지 =====
model Message {
  id         String   @id @default(cuid())
  instanceId String
  role       String   // "student" | "ai"
  content    String
  createdAt  DateTime @default(now())

  instance AIInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}
