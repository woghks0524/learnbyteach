generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== 사용자 =====
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("student") // "teacher" | "student"
  createdAt DateTime @default(now())

  // 교사 관계
  courses         Course[]
  knowledgeFiles  KnowledgeFile[]
  createdStudents User[]    @relation("CreatedBy")

  // 학생 관계
  createdById     String?
  createdBy       User?     @relation("CreatedBy", fields: [createdById], references: [id])
  enrollments     CourseEnrollment[]
  instances       AIInstance[]

  // 그룹(반) 관계
  studentGroups   StudentGroup[]        @relation("TeacherGroups") // 교사가 만든 그룹
  groupMemberships StudentGroupMember[] // 학생이 속한 그룹
}

// ===== 학생 그룹(반) — 교사가 학생을 묶어 관리 =====
model StudentGroup {
  id        String   @id @default(cuid())
  teacherId String
  name      String   // 예: "4학년 3반"
  createdAt DateTime @default(now())

  teacher User                 @relation("TeacherGroups", fields: [teacherId], references: [id])
  members StudentGroupMember[]
}

model StudentGroupMember {
  id        String @id @default(cuid())
  groupId   String
  studentId String

  group   StudentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
}

// ===== 지식파일 (교사 라이브러리) =====
model KnowledgeFile {
  id        String   @id @default(cuid())
  teacherId String
  fileName  String
  content   String
  fileType  String   // "curriculum" | "textbook" | "custom"
  subject   String   @default("") // 과목 태그
  createdAt DateTime @default(now())

  teacher User                  @relation(fields: [teacherId], references: [id])
  courses CourseKnowledgeFile[]
}

// ===== 수업-지식파일 연결 =====
model CourseKnowledgeFile {
  id              String @id @default(cuid())
  courseId         String
  knowledgeFileId String

  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  knowledgeFile KnowledgeFile @relation(fields: [knowledgeFileId], references: [id], onDelete: Cascade)

  @@unique([courseId, knowledgeFileId])
}

// ===== 수업 (핵심 단위) =====
model Course {
  id          String   @id @default(cuid())
  teacherId   String
  name        String
  subject     String
  unit        String
  gradeLevel  String
  description String?

  // AI 학생 기본 설정 (단계별 설정이 없을 때 fallback)
  comprehensionLevel String @default("medium")
  personality        String @default("curious")
  knownTopics        String @default("[]")
  unknownTopics      String @default("[]")
  misconceptions     String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher        User                  @relation(fields: [teacherId], references: [id])
  enrollments    CourseEnrollment[]
  instances      AIInstance[]
  knowledgeFiles CourseKnowledgeFile[]
  steps          LessonStep[]
}

// ===== 수업 단계 (교사가 설계) =====
model LessonStep {
  id          String   @id @default(cuid())
  courseId    String
  order       Int      // 단계 순서 (1, 2, 3...)
  title       String   // 단계 이름 (예: "사실 탐색")
  description String?  // 단계 설명/목표

  // AI 페르소나
  aiName       String  @default("AI 학생")
  aiAvatar     String  @default("default") // 아바타 키 (default/curious/challenger/shy)
  aiPersonality String @default("curious") // "passive" | "curious" | "challenging"
  aiFocus      String? // 이 단계에서 집중할 개념/질문 방향 (교사가 직접 입력)

  // 단계 완료 조건
  completionCriteria String? // 학생이 무엇을 설명해야 이 단계가 끝나는지 (AI 자가판정 기준)
  minMessages  Int     @default(6) // 안전망: 이 횟수 초과해도 완료 안 되면 '막힌 학생'으로 표시

  createdAt DateTime @default(now())

  course             Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress           StepProgress[]
  currentInstances   AIInstance[]   // 현재 이 단계에 있는 학생 인스턴스들
}

// ===== 학생별 단계 진행 상태 =====
model StepProgress {
  id         String   @id @default(cuid())
  instanceId String
  stepId     String
  completed  Boolean  @default(false)
  messages   Message[]
  createdAt  DateTime @default(now())

  instance AIInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step     LessonStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([instanceId, stepId])
}

// ===== 수업 등록 =====
model CourseEnrollment {
  id        String   @id @default(cuid())
  studentId String
  courseId   String
  createdAt DateTime @default(now())

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

// ===== AI 인스턴스 (학생별 포크) =====
model AIInstance {
  id         String   @id @default(cuid())
  courseId    String
  studentId  String
  createdAt  DateTime @default(now())

  comprehensionState String @default("{}")
  currentStepId      String? // 현재 진행 중인 단계

  course       Course         @relation(fields: [courseId], references: [id])
  student      User           @relation(fields: [studentId], references: [id])
  currentStep  LessonStep?    @relation(fields: [currentStepId], references: [id], onDelete: SetNull)
  messages     Message[]
  stepProgress StepProgress[]

  @@unique([courseId, studentId])
}

// ===== 대화 메시지 =====
model Message {
  id             String   @id @default(cuid())
  instanceId     String
  stepProgressId String?  // 어느 단계의 대화인지
  role           String   // "student" | "ai"
  content        String
  createdAt      DateTime @default(now())

  instance     AIInstance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepProgress StepProgress? @relation(fields: [stepProgressId], references: [id])
}
