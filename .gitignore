# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client을 보통은 무시하지만,
# 현재 `prisma generate`가 ESM 충돌로 깨져있어서 수동 패치된 client를 commit해야 배포 가능.
# Prisma 도구 살아나면(Node 20.19+로 업그레이드 후 prisma@7.8+) 이 라인 다시 켜고 generated 무시.
# /src/generated/prisma
*.db
scripts/test-results*.json
supabase/
